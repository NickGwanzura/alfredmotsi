{
  "name": "splash-air-app",
  "version": "1.0.0",
  "description": "Next.js application with PostgreSQL for Dokploy",
  "type": "docker-compose",
  "dockerComposeFile": "docker-compose.yml",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "ports": [
    {
      "containerPort": 3000,
      "hostPort": 3000
    }
  ],
  "healthCheck": {
    "path": "/",
    "port": 3000,
    "interval": 30,
    "timeout": 10,
    "retries": 3
  },
  "env": {
    "NODE_ENV": "production",
    "DATABASE_URL": "${DATABASE_URL}",
    "NEXTAUTH_SECRET": "${NEXTAUTH_SECRET}",
    "NEXTAUTH_URL": "${NEXTAUTH_URL}",
    "RESEND_API_KEY": "${RESEND_API_KEY}",
    "FROM_EMAIL": "${FROM_EMAIL}"
  },
  "volumes": [],
  "dependsOn": ["db"]
}
