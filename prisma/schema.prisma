generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  admin
  tech
  client
}

enum TechStatus {
  available
  on_site   @map("on-site")
  in_transit @map("in-transit")
}

enum JobType {
  installation
  maintenance
  repair
  sales
  inspection
  callout
}

enum JobStatus {
  scheduled
  in_progress @map("in-progress")
  on_site     @map("on-site")
  completed
  cancelled
  pending_parts @map("pending-parts")
  unallocated
  pending_booking @map("pending-booking")
}

enum JobPriority {
  urgent
  high
  medium
  low
}

enum IssueType {
  install
  repair
  service
  quote
}

enum UnitType {
  Split_System   @map("Split System")
  Ducted
  Package_Unit   @map("Package Unit")
  Multi_Head     @map("Multi-Head")
  Cassette
  VRV_VRF        @map("VRV/VRF")
  Refrigeration_System @map("Refrigeration System")
  Chiller
  Heat_Pump      @map("Heat Pump")
  Precision_Cooling @map("Precision Cooling")
}

enum RefrigerantType {
  R_32  @map("R-32")
  R_410A @map("R-410A")
  R_22   @map("R-22")
  R_134a @map("R-134a")
  R_407C @map("R-407C")
  R_600A @map("R-600A")
  R_290  @map("R-290")
}

enum SystemStatus {
  optimal
  sub_optimal @map("sub-optimal")
  critical
}

enum AlertType {
  HIGH_CURRENT
  LOW_VOLTAGE
  HIGH_TEMP
  PRESSURE_LEAK
}

enum JobSource {
  admin
  portal
}

enum CRMType {
  call
  visit
  complaint
  email
  quote
}

enum CRMOutcome {
  positive
  negative
  pending
  resolved
}

enum ConsumableType {
  gas
  compressor
  part
  other
}

enum AuditAction {
  login
  view_job
  edit_job
  complete_job
}

// ============================================
// AUTH MODELS (NextAuth.js)
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// USER MODEL
// ============================================

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  emailVerified   DateTime? @map("email_verified")
  role            UserRole
  password        String    // Hashed password (replaces pin)
  passwordChanged Boolean   @default(false) @map("password_changed") // Track if user changed temp password
  phone           String?
  specialty       String?
  status          TechStatus?
  image           String?   // Avatar URL
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Auth relations
  accounts      Account[]
  sessions      Session[]

  // App relations
  assignedJobs    Job[] @relation("AssignedJobs")
  coAssignedJobs  Job[] @relation("CoAssignedJobs")
  gasUsageRecords GasUsageRecord[]
  crmRecords      CRMRecord[]
  consumables     Consumable[]
  auditLogs       AuditLog[]

  @@map("users")
}

// ============================================
// CORE APP MODELS
// ============================================

model Customer {
  id            String   @id @default(cuid())
  name          String
  address       String
  siteAddress   String?  @map("site_address")
  phone         String
  whatsapp      String?
  email         String   @unique
  portalCode    String?  @unique @map("portal_code")
  portalEnabled Boolean  @default(false) @map("portal_enabled")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  jobs       Job[]
  crmRecords CRMRecord[]

  @@map("customers")
}

model Job {
  id          String     @id @default(cuid())
  source      JobSource
  customerId  String     @map("customer_id")
  title       String
  type        JobType
  unitType    UnitType   @map("unit_type")
  issue       IssueType
  priority    JobPriority
  date        String
  time        String
  status      JobStatus
  clockIn     String?    @map("clock_in")
  clockOut    String?    @map("clock_out")
  description String
  photos      String[]
  signature   String?
  jobCardRef  String     @unique @map("job_card_ref")
  alerts      AlertType[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  technicians   User[] @relation("AssignedJobs")
  coTechnicians User[] @relation("CoAssignedJobs")
  
  diagnostics   Diagnostics?
  comments      Comment[]
  history       HistoryEntry[]
  recurring     RecurringSchedule?
  gasUsageRecords GasUsageRecord[]
  consumables   Consumable[]
  auditLogs     AuditLog[]

  @@map("jobs")
}

model Diagnostics {
  id                   String          @id @default(cuid())
  jobId                String          @unique @map("job_id")
  voltage              String?
  current              String?
  avgTemp              String?         @map("avg_temp")
  maxTemp              String?         @map("max_temp")
  suction              String?
  discharge            String?
  refrigerantType      RefrigerantType? @map("refrigerant_type")
  refrigerantRecovered Float?          @map("refrigerant_recovered")
  refrigerantUsed      Float?          @map("refrigerant_used")
  refrigerantReused    Float?          @map("refrigerant_reused")
  status               SystemStatus?
  notes                String?
  deltaT               String?         @map("delta_t")
  brand                String?
  serial               String?

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("diagnostics")
}

model Comment {
  id        String   @id @default(cuid())
  jobId     String   @map("job_id")
  author    String
  text      String
  time      String
  createdAt DateTime @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model HistoryEntry {
  id        String   @id @default(cuid())
  jobId     String   @map("job_id")
  date      String
  note      String
  createdAt DateTime @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("history_entries")
}

model RecurringSchedule {
  id       String @id @default(cuid())
  jobId    String @unique @map("job_id")
  interval Int
  unit     String @default("months")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("recurring_schedules")
}

model GasStockItem {
  id           String   @id @default(cuid())
  gasType      String   @map("gas_type")
  brand        String
  quantity     Float
  remaining    Float
  unit         String
  supplier     String
  supplierRef  String   @map("supplier_ref")
  addedBy      String   @map("added_by")
  date         String
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  usageRecords GasUsageRecord[]

  @@map("gas_stock")
}

model GasUsageRecord {
  id           String   @id @default(cuid())
  stockId      String   @map("stock_id")
  gasType      String   @map("gas_type")
  quantityUsed Float    @map("quantity_used")
  usedBy       String   @map("used_by")
  jobId        String   @map("job_id")
  customer     String
  date         String
  time         String
  purpose      String
  createdAt    DateTime @default(now()) @map("created_at")

  stockItem GasStockItem @relation(fields: [stockId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [usedBy], references: [id], onDelete: Cascade)
  job       Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("gas_usage")
}

model CRMRecord {
  id           String      @id @default(cuid())
  customerId   String      @map("customer_id")
  type         CRMType
  subject      String
  body         String
  date         String
  time         String
  by           String
  followUp     String?     @map("follow_up")
  followUpDone Boolean     @default(false) @map("follow_up_done")
  outcome      CRMOutcome
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [by], references: [id], onDelete: Cascade)

  @@map("crm_records")
}

model Consumable {
  id         String          @id @default(cuid())
  jobId      String          @map("job_id")
  type       ConsumableType
  name       String
  brand      String?
  model      String?
  quantity   Float
  unit       String
  notes      String?
  recordedBy String          @map("recorded_by")
  recordedAt DateTime        @default(now()) @map("recorded_at")

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [recordedBy], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("consumables")
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  userName  String      @map("user_name")
  action    AuditAction
  jobId     String?     @map("job_id")
  latitude  Float?
  longitude Float?
  accuracy  Float?
  ipAddress String?     @map("ip_address")
  userAgent String?     @map("user_agent")
  createdAt DateTime    @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job?  @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([jobId])
  @@map("audit_logs")
}
