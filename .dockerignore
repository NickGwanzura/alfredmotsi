# Dockerignore for Next.js app
# NOTE: Do NOT exclude node_modules/.prisma - it's needed for Prisma Client

# Build outputs (these are rebuilt)
.next
out
dist

# Testing
coverage

# Environment files (sensitive)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Git
.git
.gitignore

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Misc
README.md
CHANGELOG.md
*.md
.github
docs
